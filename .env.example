# --- API Keys ---
# Required: Replace with your real OpenAI API key
OPENAI_API_KEY=sk-your-key-here

# --- Docker Configuration ---
# This is the default for docker-compose. You do not need to change this.
# The `+psycopg2` tells SQLAlchemy to use the synchronous driver we have installed.
DATABASE_URL=postgresql+psycopg2://user:pass@db:5432/intake_agent

# This is used by the UI to connect to the backend API within Docker.
API_URL=http://api:8000

# --- Application Settings ---
# Set to 'mock', 'jira', 'monday', or 'planner'
PM_TOOL_TYPE=mock
# Set to 'openai' or 'anthropic' (requires ANTHROPIC_API_KEY)
LLM_PROVIDER=openai

# --- Security & Compliance ---
RISK_SCORE=8
AUDIT_NOTIFICATION_CHANNEL=none # Options: slack, email, webhook

# --- Optional PM Tool Credentials ---
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=user@example.com
JIRA_API_TOKEN=your-token
JIRA_PROJECT_KEY=PROJ

MONDAY_API_KEY=your-monday-api-key
MONDAY_BOARD_ID=123456789
MONDAY_FILES_COLUMN_ID=file

MS_TENANT_ID=your-tenant-id
MS_CLIENT_ID=your-client-id
MS_CLIENT_SECRET=your-client-secret
MS_PLANNER_PLAN_ID=your-plan-id
MS_PLANNER_BUCKET_ID=your-bucket-id
MS_SHAREPOINT_DRIVE_ID=your-drive-id-for-uploads
